# Скопіюйте у .env у цій теці (salon-bot-engine)

# Шлях до теки data сайту (там messenger-tenants.json). Якщо порожньо — шукає ../data від кореня репозиторію.
# SALON_DATA_DIR=C:\Users\vadim\Downloads\glam_nails\data

# Або повний шлях до файлу:
# SALON_TENANTS_JSON=C:\path\to\data\messenger-tenants.json

# --- Telegram (run_telegram.py) ---
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram chat IDs allowed to run /test and send a test message to all Telegram subscribers (from messenger-tenants.json). Your ID: message @userinfobot or check bot logs after /start.
# SALON_BROADCAST_ADMIN_CHAT_IDS=123456789
# Pause between outbound messages (seconds) — lowers Flood risk with many subscribers.
# TELEGRAM_SEND_MIN_INTERVAL_SEC=0.06
# Max jobs waiting to send (backpressure if full).
# TELEGRAM_OUTBOUND_QUEUE_MAX=50000

# --- WhatsApp Green API (run_whatsapp.py) ---
GREENAPI_URL=https://api.green-api.com
GREENAPI_ID_INSTANCE=
GREENAPI_TOKEN=
IGNORE_WA_GROUPS=true
